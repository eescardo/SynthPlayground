{
  "name": "synth-playground",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:wasm": "npm run build:wasm && npm run dev",
    "dev:wasm:strict": "npm run build:wasm && NEXT_PUBLIC_STRICT_WASM=1 npm run dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "build:wasm": "cd rust/dsp-core && wasm-pack build --target web --out-dir ../../public/wasm/pkg"
  },
  "dependencies": {
    "idb": "^8.0.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.1.0",
    "typescript": "^5.7.2"
  }
}

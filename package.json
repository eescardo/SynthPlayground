{
  "name": "synth-playground",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:wasm": "npm run build:wasm && npm run dev",
    "dev:wasm:strict": "npm run build:wasm && NEXT_PUBLIC_STRICT_WASM=1 npm run dev",
    "build": "pnpm run check:presets:manifest && next build",
    "start": "next start",
    "lint": "pnpm run check:presets:manifest && next lint",
    "validate": "pnpm run typecheck && pnpm run test:unit && pnpm run lint && pnpm run build",
    "test:ui:capture": "playwright test tests/ui/screenshot-scenarios.spec.ts",
    "test:ui:capture:main-view": "playwright test tests/ui/screenshot-scenarios.spec.ts --grep @main-view",
    "test:ui:capture:help-modal": "playwright test tests/ui/screenshot-scenarios.spec.ts --grep @help-modal",
    "test:ui:capture:record-mode": "playwright test tests/ui/screenshot-scenarios.spec.ts --grep @record-mode",
    "test:ui:capture:patch-editor": "playwright test tests/ui/screenshot-scenarios.spec.ts --grep @patch-editor",
    "presets:manifest": "node --import tsx scripts/generate-preset-manifest.ts --write",
    "check:presets:manifest": "node --import tsx scripts/check-preset-manifest.ts",
    "check:presets:compat": "node scripts/check-preset-compatibility.mjs",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "build:wasm": "cd rust/dsp-core && wasm-pack build --target web --out-dir ../../public/wasm/pkg"
  },
  "dependencies": {
    "idb": "^8.0.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.0"
  }
}

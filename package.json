{
  "name": "synth-playground",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "sync:worklet-runtime": "node scripts/worklets/sync-worklet-runtime.mjs",
    "dev:next": "pnpm run sync:worklet-runtime && next dev",
    "dev": "pnpm run build:wasm && pnpm run dev:next",
    "build": "pnpm run build:wasm && pnpm run build:next",
    "build:next": "pnpm run sync:worklet-runtime && pnpm run check:presets:manifest && next build",
    "start": "next start",
    "format": "prettier . --write && pnpm run format:rust",
    "format:check": "prettier . --check && pnpm run format:rust:check",
    "format:rust": "cargo fmt --manifest-path rust/dsp-core/Cargo.toml",
    "format:rust:check": "cargo fmt --manifest-path rust/dsp-core/Cargo.toml --check",
    "lint": "pnpm run format:check && pnpm run sync:worklet-runtime && pnpm run check:presets:manifest && pnpm run check:node-params && next lint",
    "validate": "pnpm run typecheck && pnpm run build:wasm && pnpm run test:unit:prepared && pnpm run lint && pnpm run build:next",
    "test:ui:capture": "pnpm run sync:worklet-runtime && node --import tsx scripts/ui-screenshots/capture.ts",
    "test:ui:video:capture": "pnpm run sync:worklet-runtime && node --import tsx scripts/ui-videos/capture.ts",
    "test:ui:verify": "vitest run --config vitest.ui.config.ts",
    "benchmark:audio": "node --expose-gc --import tsx scripts/audio-benchmarks/run.ts",
    "benchmark:audio:compare": "node --import tsx scripts/audio-benchmarks/compare.ts",
    "profile:audio": "node --expose-gc --import tsx scripts/audio-benchmarks/profile-audio.ts",
    "profile:preview-probes": "node --expose-gc --import tsx scripts/audio-benchmarks/profile-preview-probes.ts",
    "release:tag": "node scripts/release/create-release-tag.mjs",
    "presets:manifest": "node --import tsx scripts/generate-preset-manifest.ts --write",
    "node-params": "node --import tsx scripts/generate-node-params.ts",
    "rust:node-params": "pnpm run node-params",
    "check:presets:manifest": "node --import tsx scripts/check-preset-manifest.ts",
    "check:node-params": "node --import tsx scripts/check-node-params.ts",
    "check:rust:node-params": "pnpm run check:node-params",
    "check:presets:definitions": "node --import tsx scripts/check-preset-definitions.ts",
    "check:presets:compat": "node scripts/check-preset-compatibility.mjs",
    "test:unit": "pnpm run build:wasm && pnpm run test:unit:prepared",
    "test:unit:prepared": "pnpm run sync:worklet-runtime && vitest run",
    "test:unit:watch": "vitest",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "build:wasm": "cd rust/dsp-core && RUSTFLAGS='-C target-feature=+simd128' wasm-pack build --release --target web --out-dir ../../public/wasm/pkg"
  },
  "dependencies": {
    "idb": "^8.0.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.1.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.0"
  }
}
